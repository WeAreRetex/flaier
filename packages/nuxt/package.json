{
  "name": "@flaier/nuxt",
  "version": "0.1.8",
  "description": "Nuxt module and wrapper components for Flaier flows in Nuxt and Docus.",
  "keywords": [
    "diagram",
    "docus",
    "flaier",
    "flow",
    "nuxt"
  ],
  "homepage": "https://github.com/WeAreRetex/flaier/tree/main/packages/nuxt#readme",
  "bugs": {
    "url": "https://github.com/WeAreRetex/flaier/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeAreRetex/flaier.git",
    "directory": "packages/nuxt"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "default": "./dist/module.mjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.0",
    "@shikijs/twoslash": "^3",
    "shiki": "^3",
    "twoslash": "^0.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@flaier/core": "workspace:*",
    "nuxt": "^4.4.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "nuxt": "^4.4.0"
  }
}
