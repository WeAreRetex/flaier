        "activate": [
          "worker"
        ],
        "deactivate": [
          "queue"
        ],
        "sourceAnchor": "src/workers/delivery.ts:22"
      }
    },
    "group-delivery-result": {
      "type": "SequenceGroup",
      "props": {
        "kind": "alt",
        "label": "Provider accepts delivery?",
        "description": "Successful attempts finish the worker. Retryable failures compute the next delay.",
