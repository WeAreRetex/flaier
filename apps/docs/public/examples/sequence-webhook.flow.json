        "activate": [
          "queue"
        ],
        "sourceAnchor": "src/server/routes/webhooks.post.ts:34"
      }
    },
    "msg-accepted": {
      "type": "SequenceMessage",
      "props": {
        "from": "edge",
        "to": "provider",
        "label": "202 Accepted",
        "description": "The provider gets an immediate acknowledgement while delivery continues in the background.",
        "kind": "return",
        "deactivate": [
          "edge"
        ],
        "sourceAnchor": "src/server/routes/webhooks.post.ts:41"
      }
    },
    "note-delivery-contract": {
      "type": "SequenceNote",
