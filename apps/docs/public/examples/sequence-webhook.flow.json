    "branch-retryable": {
      "type": "SequenceBranch",
      "props": {
        "label": "Retryable failure"
      },
      "children": [
        "msg-deliver-failed",
        "msg-backoff",
        "note-backoff"
      ]
    },
    "msg-deliver": {
      "type": "SequenceMessage",
      "props": {
        "from": "worker",
        "to": "provider",
        "label": "POST event payload",
        "description": "Worker sends the transformed event to the provider callback endpoint.",
        "kind": "async",
        "sourceAnchor": "src/workers/delivery.ts:36"
      }
    },
    "msg-ok": {
      "type": "SequenceMessage",
      "props": {
        "from": "provider",
        "to": "worker",
        "label": "200 OK",
        "description": "Remote endpoint accepts the event and the worker finishes the job.",
        "kind": "return",
        "deactivate": [
          "worker"
        ],
        "sourceAnchor": "src/workers/delivery.ts:42"
      }
    },
    "msg-deliver-failed": {
      "type": "SequenceMessage",
      "props": {
        "from": "worker",
        "to": "provider",
        "label": "POST event payload",
        "description": "Worker attempts delivery but receives a transient error response.",
        "kind": "async",
        "sourceAnchor": "src/workers/delivery.ts:36"
      }
    },
    "msg-backoff": {
      "type": "SequenceMessage",
      "props": {
        "from": "worker",
        "to": "worker",
        "label": "Compute exponential backoff",
        "description": "Self-message showing retry window calculation before the next attempt is scheduled.",
        "kind": "sync",
        "deactivate": [
          "worker"
        ],
        "sourceAnchor": "src/workers/delivery.ts:48"
      }
    },
    "note-backoff": {
      "type": "SequenceNote",
      "props": {
        "label": "Retry metadata",
        "body": "Delivery attempts record the error class, next scheduled timestamp, and cumulative failure count.",
        "placement": "left-of",
        "participants": [
          "worker"
        ],
        "sourceAnchor": "docs/runbooks/webhooks.md:14"
      }
    },
    "group-escalate": {
      "type": "SequenceGroup",
      "props": {
        "kind": "opt",
        "label": "Repeated failure threshold reached",
        "description": "Only page the on-call if retries are exhausted or the destination stays unhealthy.",
        "sourceAnchor": "src/workers/delivery.ts:58"
      },
      "children": [
        "branch-escalate"
      ]
    },
    "branch-escalate": {
      "type": "SequenceBranch",
      "props": {
        "label": "Escalate"
      },
      "children": [
        "msg-alert",
        "note-alert"
      ]
    },
    "msg-alert": {
      "type": "SequenceMessage",
      "props": {
        "from": "worker",
        "to": "ops",
        "label": "Send on-call alert",
        "description": "Worker opens an incident with the latest failure payload and retry history.",
        "kind": "async",
        "activate": [
          "ops"
        ],
        "deactivate": [
          "ops"
        ],
        "sourceAnchor": "src/workers/delivery.ts:61"
      }
    },
    "note-alert": {
      "type": "SequenceNote",
      "props": {
        "label": "Escalation payload",
        "body": "The alert links the destination runbook, last response body, and a replay token for manual recovery.",
