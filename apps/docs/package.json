{
  "name": "@flaier/docs",
  "version": "0.1.5",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --extends docus",
    "prebuild": "pnpm --dir ../../packages/core build",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 nuxt build --extends docus",
    "pregenerate": "pnpm --dir ../../packages/core build",
    "generate": "NUXT_CONTENT_LOCAL_DB=.data/content/generate.sqlite nuxt generate --extends docus",
    "preview": "NUXT_CONTENT_LOCAL_DB=.data/content/preview.sqlite nuxt preview --extends docus"
  },
  "dependencies": {
    "@flaier/core": "workspace:*",
    "@flaier/nuxt": "workspace:*",
    "@takumi-rs/wasm": "0.73.1",
    "docus": "^5.9.0",
    "nuxt": "^4.4.2",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
