{
  "name": "flaier",
  "version": "0.2.9",
  "private": true,
  "description": "Spec-driven flow visualizer for AI-generated codebase storytelling.",
  "homepage": "https://github.com/WeAreRetex/flaier#readme",
  "bugs": {
    "url": "https://github.com/WeAreRetex/flaier/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WeAreRetex/flaier.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vp run @flaier/viewer#dev",
    "build": "vp run @flaier/core#build",
    "test": "vp test",
    "check": "vp run @flaier/core#check",
    "typecheck": "vp run @flaier/core#typecheck",
    "flows:manifest": "vp exec tsx ./scripts/build-flow-manifest.ts",
    "docs:dev": "vp run @flaier/docs#dev",
    "docs:build": "vp run @flaier/docs#build",
    "slides:dev": "vp run @flaier/slides#dev",
    "slides:build": "vp run @flaier/slides#build",
    "viewer:dev": "vp run @flaier/viewer#dev",
    "viewer:build": "vp run @flaier/viewer#build",
    "agents:scaffold": "FLAIER_ROOT=$PWD vp run @flaier/agents#scaffold",
    "agents:manifest": "FLAIER_ROOT=$PWD vp run @flaier/agents#manifest",
    "agents:validate": "FLAIER_ROOT=$PWD vp run @flaier/agents#validate",
    "version:sync": "node ./scripts/sync-workspace-version.mjs",
    "release": "node ./scripts/release.mjs && git push --follow-tags",
    "release:minor": "node ./scripts/release.mjs minor && git push --follow-tags",
    "release:major": "node ./scripts/release.mjs major && git push --follow-tags"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@json-render/core": "^0.17.0",
    "@json-render/vue": "^0.17.0",
    "@shikijs/twoslash": "^3",
    "@vue-flow/core": "^1",
    "html-to-image": "^1.11.11",
    "jspdf": "^2.5.2",
    "shiki": "^3",
    "shiki-magic-move": "^0.5",
    "twoslash-cdn": "^0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@vitejs/plugin-vue": "^6.0.6",
    "changelogen": "^0.6.2",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plus": "^0.1.16",
    "vue": "^3.5",
    "vue-tsc": "^2"
  },
  "packageManager": "pnpm@10.33.0",
  "changelog": {
    "repo": "WeAreRetex/flaier"
  }
}
